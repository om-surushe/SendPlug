# SMTP intake (local applications authenticate with these generated credentials)
SMTP_HOST=0.0.0.0
SMTP_PORT=8025
ENABLE_AUTH=true
SMTP_AUTH_USERNAME=smtp-client
SMTP_AUTH_PASSWORD=generate-a-long-random-password
ENABLE_TLS=false
MAX_MESSAGE_SIZE=26214400

# HTTP admin/API
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
API_PREFIX=/api/v1
ENVIRONMENT=production
ADMIN_ORIGIN=https://smtp.nirmaker.com
PUBLIC_URL=https://smtp.nirmaker.com
DEBUG=false

# Admin login (Gmail credentials are added in the UI, never here)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=generate-a-long-random-password
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional customer Google sign-in. Leave blank to keep recovery-admin login only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://smtp.nirmaker.com/auth/google/callback
AUTH_SIGNUPS_ENABLED=true

# Flower diagnostics
FLOWER_USER=admin
FLOWER_PASSWORD=generate-a-long-random-password

# Required files under ./secrets/ (all ignored by git):
# credential_key — generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# token_pepper   — generate with: openssl rand -hex 32
# jwt_secret     — generate with: openssl rand -hex 64
