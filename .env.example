# ---------------------------------------------------------------
# Copy this file to .env and fill in the values before deploying.
# ---------------------------------------------------------------

# SMTP Server (listening)
SMTP_HOST=0.0.0.0
SMTP_PORT=8025
ENABLE_AUTH=true
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=your_gmail_app_password
ENABLE_TLS=false
MAX_MESSAGE_SIZE=26214400

# HTTP API
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
API_PREFIX=/api/v1
DEBUG=false

# JWT — CHANGE THIS to a long random string in production
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin login for /auth/login endpoint
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# Gmail SMTP relay (outbound)
GMAIL_SMTP_SERVER=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_USE_TLS=true

# Redis (set automatically in docker-compose, override only if using external Redis)
# REDIS_URL=redis://redis:6379/0

# Flower dashboard basic auth
FLOWER_USER=admin
FLOWER_PASSWORD=changeme
