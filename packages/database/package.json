{
  "name": "@sendplug/database",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "typecheck": "bunx tsc -p tsconfig.json",
    "db:generate": "bunx --bun prisma generate",
    "db:migrate": "bunx --bun prisma migrate dev",
    "db:validate": "bunx --bun prisma validate",
    "test:integration": "bun test test/prisma.integration.test.ts",
    "db:import:sqlite": "bun src/import-sqlite.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.9.0",
    "@prisma/client": "7.9.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/pg": "8.20.0",
    "prisma": "7.9.0",
    "typescript": "7.0.2"
  }
}
