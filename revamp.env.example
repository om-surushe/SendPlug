# Bun/Elysia replacement stack (development only)
NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=3000
DATABASE_URL=postgresql://sendplug:replace-local-password@127.0.0.1:5433/sendplug?schema=public
REDIS_URL=redis://127.0.0.1:6380/0
POSTGRES_PASSWORD=replace-local-password

# WorkOS AuthKit — configure only after creating the WorkOS project.
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# Gmail scopes are requested dynamically during mailbox connection, not during login.
